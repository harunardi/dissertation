@article{gongDataEnabledPhysicsInformedMachine2022,
  title = {Data-{{Enabled Physics-Informed Machine Learning}} for {{Reduced-Order Modeling Digital Twin}}: {{Application}} to {{Nuclear Reactor Physics}}},
  shorttitle = {Data-{{Enabled Physics-Informed Machine Learning}} for {{Reduced-Order Modeling Digital Twin}}},
  author = {Gong, Helin and Cheng, Sibo and Chen, Zhang and Li, Qing},
  date = {2022-06-03},
  journaltitle = {Nuclear Science and Engineering},
  volume = {196},
