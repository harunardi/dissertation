@article{vidal-ferrandizMovingMeshesSolve2016,
  title = {Moving Meshes to Solve the Time-Dependent Neutron Diffusion Equation in Hexagonal Geometry},
  author = {Vidal-Ferràndiz, A. and Fayez, R. and Ginestar, D. and Verdú, G.},
  date = {2016-01-01},
  journaltitle = {Journal of Computational and Applied Mathematics},
  shortjournal = {Journal of Computational and Applied Mathematics},
  series = {Mathematical {{Modeling}} and {{Computational Methods}}},
  volume = {291},
  pages = {197--208},
  issn = {0377-0427},
  doi = {10.1016/j.cam.2015.03.040},
  %url = {https://www.sciencedirect.com/science/article/pii/S0377042715001934},
  %urldate = {2023-10-29},
  abstract = {To simulate the behaviour of a nuclear power reactor it is necessary to be able to integrate the time-dependent neutron diffusion equation inside the reactor core. Here the spatial discretization of this equation is done using a finite element method that permits h–p refinements for different geometries. This means that the accuracy of the solution can be improved refining the spatial mesh (h-refinement) and also increasing the degree of the polynomial expansions used in the finite element method (p-refinement). Transients involving the movement of the control rod banks have the problem known as the rod-cusping effect. Previous studies have usually approached the problem using a fixed mesh scheme defining averaged material properties. The present work proposes the use of a moving mesh scheme that uses spatial meshes that change with the movement of the control rods avoiding the necessity of using equivalent material cross sections for the partially inserted cells. The performance of the moving mesh scheme is tested studying one-dimensional and three-dimensional benchmark problems.},
  keywords = {Finite element method,Moving mesh scheme,Neutron diffusion equation,Rod-cusping problem},
  file = {/home/haruna2/snap/zotero-snap/common/Zotero/storage/5IH63CHQ/Vidal-Ferràndiz et al. - 2016 - Moving meshes to solve the time-dependent neutron .pdf;/home/haruna2/snap/zotero-snap/common/Zotero/storage/36RYVDFV/S0377042715001934.html}
}

@article{vidal-ferrandizNeutronicSimulationFuel2020,
  title = {Neutronic {{Simulation}} of {{Fuel Assembly Vibrations}} in a {{Nuclear Reactor}}},
  author = {Vidal-Ferràndiz, A. and Carreño, A. and Ginestar, D. and Demazière, C. and Verdú, G.},
  date = {2020-11-01},
  journaltitle = {Nuclear Science and Engineering},
  shortjournal = {Nuclear Science and Engineering},
  volume = {194},
  number = {11},
  pages = {1067--1078},
  issn = {0029-5639, 1943-748X},
  doi = {10.1080/00295639.2020.1756617},
  %url = {https://www.tandfonline.com/doi/full/10.1080/00295639.2020.1756617},
  %urldate = {2023-01-14},
  abstract = {The mechanical vibrations of fuel assemblies have been shown to give rise to high levels of neutron noise, triggering in some circumstances the necessity to operate nuclear reactors at a reduced power level. This work simulates and analyses the effect in the neutron field of the oscillation of one single fuel assembly without considering thermal-hydraulic feedback. The amplitude of the fuel assembly vibration ranges from 0 to 1 millimetres and this implies the use of fine meshes and accurate numerical solvers. Results show two different effects in the neutron field caused by the fuel assembly vibration. First, a global slow variation of the total neutron power due to a change in the criticality of the system. Second, an in-phase change in the neutron flux with the assembly vibration. This second effect is more important and has a strong spatial dependence. This paper shows a comparison between a time domain analysis and a frequency domain analysis of the phenomena, in order to validate the time domain solution against the frequency domain solution. Numerical results shows a really close match between these two approaches.},
  langid = {english},
  file = {/home/haruna2/snap/zotero-snap/common/Zotero/storage/R23BUF4U/Vidal-Ferràndiz et al. - 2020 - Neutronic Simulation of Fuel Assembly Vibrations i.pdf}
}

@article{wachInvestigationJointEffect1974,
  title = {Investigation of the {{Joint Effect}} of {{Local}} and {{Global Driving Sources}} in {{In-Core Neutron Noise Measurements}}},
  author = {Wach, D and Kosály, G},
  date = {1974},
  journaltitle = {Atomkernenergie},
  volume = {23},
  number = {4},
  pages = {244--250},
  abstract = {The local effect caused by the steam-voids of a boiling water reactor in the noise signals of incore ion chambers has been proved by measurements and used for practical application in recent times. From the linear phase function of two detectors placed one above the other in the same radial position the mean transit time of the bubbles has been taken and used for the evaluation of the local steam-void velocity. The concepts of local and global driving sources of the neutron noise are introduced and their joint effect is investigated. The transfer function derived from the model is compared to the experimental results. The agreement between theoretical predictions and experimental findings supports the validity of the model.}
}

